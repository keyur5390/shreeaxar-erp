{
  "name": "shreeaxar/quotation-erp",
  "description": "Ready-to-use quotation management ERP for Shree Axar Furniture.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.2",
    "ext-pdo": "*",
    "ext-json": "*",
    "ext-mbstring": "*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "scripts": {
    "test": "php artisan test",
    "migrate": "php artisan migrate --seed"
  },
  "config": {
    "sort-packages": true
  }
}
