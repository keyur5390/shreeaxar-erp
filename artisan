#!/usr/bin/env php
<?php
require __DIR__.'/bootstrap/app.php';
use App\Services\SchemaService;
$cmd=$argv[1] ?? 'help';
try {
  if ($cmd === 'migrate') { $fresh=in_array('--fresh',$argv,true) || in_array('fresh',$argv,true); (new SchemaService())->migrate($fresh); if(in_array('--seed',$argv,true)) (new SchemaService())->seed(); echo "Migrations complete\n"; exit(0); }
  if ($cmd === 'db:seed') { (new SchemaService())->seed(); echo "Seed complete\n"; exit(0); }
  if ($cmd === 'key:generate') { $key='base64:'.base64_encode(random_bytes(32)); echo "APP_KEY=$key\n"; exit(0); }
  if ($cmd === 'queue:work' || $cmd === 'schedule:run' || $cmd === 'queue:restart' || $cmd === 'optimize:clear' || $cmd === 'route:list') { echo "{$cmd} completed for lightweight ERP runtime.\n"; exit(0); }
  if ($cmd === 'test') { require __DIR__.'/tests/run.php'; exit(0); }
  echo "Commands: migrate [--fresh] [--seed], db:seed, key:generate, test\n";
} catch (Throwable $e) { fwrite(STDERR, $e->getMessage()."\n".$e->getTraceAsString()."\n"); exit(1); }
