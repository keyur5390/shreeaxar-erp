APP_NAME="Shree Axar ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_PORT=8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=shreeaxar_erp
DB_USERNAME=erp_user
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root_secret
DB_FORWARD_PORT=3306

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379
REDIS_FORWARD_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@shreeaxar.local
MAIL_FROM_NAME="${APP_NAME}"

FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log
